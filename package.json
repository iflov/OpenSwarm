{
  "name": "openswarm",
  "version": "0.1.0",
  "description": "Autonomous Claude Code agents orchestrator with Discord control and Linear memory",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openswarm": "dist/cli.js"
  },
  "scripts": {
    "predev": "pkill -TERM -f 'node --env-file=.env .*src/index.ts' 2>/dev/null || true",
    "dev": "node --env-file=.env --import=tsx src/index.ts",
    "prestart": "pkill -TERM -f 'node --env-file=.env .*dist/index.js' 2>/dev/null || true",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "stop": "sh -c 'killed=0; pkill -TERM -f \"node --env-file=.env .*src/index.ts\" && killed=1; pkill -TERM -f \"node --env-file=.env .*dist/index.js\" && killed=1; [ \"$killed\" -eq 1 ] || echo \"No process running\"'",
    "lint": "oxlint src/",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/vitest/vitest.mjs run",
    "test:watch": "node --experimental-vm-modules node_modules/vitest/vitest.mjs",
    "chat": "node --env-file=.env --import=tsx src/support/chat.ts",
    "cli:dev": "node --env-file=.env --import=tsx src/cli.ts",
    "ci": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@lancedb/lancedb": "^0.23.0",
    "@linear/sdk": "^19.0.0",
    "@types/blessed": "^0.1.27",
    "@xenova/transformers": "^2.17.2",
    "apache-arrow": "^18.1.0",
    "blessed": "^0.1.81",
    "commander": "^12.1.0",
    "croner": "^8.0.0",
    "discord.js": "^14.14.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.1.0",
    "oxlint": "^1.43.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  }
}
